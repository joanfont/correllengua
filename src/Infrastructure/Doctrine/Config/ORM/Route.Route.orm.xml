<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                    https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
    <entity name="App\Domain\Model\Route\Route" table="route">
        <id name="id" length="36">
            <generator strategy="NONE" />
        </id>

        <field name="name" length="128" />
        <field name="description" type="text" />
        <field name="startsAt" type="date" />

        <one-to-many field="itineraries" target-entity="App\Domain\Model\Route\Itinerary" mapped-by="route">
            <cascade>
                <cascade-all />
            </cascade>
        </one-to-many>
    </entity>
</doctrine-mapping>
