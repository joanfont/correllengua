<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                    https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
    <entity name="App\Domain\Model\Route\Segment" table="segment">
        <id name="id" length="36">
            <generator strategy="NONE" />
        </id>
        <field name="position" type="integer" />
        <embedded name="start" class="App\Domain\Model\Coordinates" column-prefix="start_" />
        <embedded name="end" class="App\Domain\Model\Coordinates" column-prefix="end_" />
        <field name="capacity" type="integer" />
        <field name="modality" type="modality" />

        <many-to-one field="itinerary" target-entity="App\Domain\Model\Route\Itinerary" inversed-by="segments">
            <join-column name="itinerary_id" nullable="false"/>
        </many-to-one>

        <one-to-many
                field="registrations"
                target-entity="App\Domain\Model\Registration\Registration"
                mapped-by="segment"
        >
            <cascade>
                <cascade-all />
            </cascade>
        </one-to-many>
    </entity>
</doctrine-mapping>
