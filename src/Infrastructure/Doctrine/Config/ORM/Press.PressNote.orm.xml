<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                    https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
    <entity name="App\Domain\Model\Press\PressNote" table="press_note">
        <id name="id" length="36">
            <generator strategy="NONE" />
        </id>

        <field name="title" />
        <field name="subtitle" />
        <field name="body" />

        <one-to-one field="image" target-entity="App\Domain\Model\File\File">
            <cascade>
                <cascade-all />
            </cascade>
        </one-to-one>

        <field name="featured" type="boolean" />

        <field name="link" length="2048" nullable="true" />
    </entity>
</doctrine-mapping>
