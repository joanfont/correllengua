<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                    https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
    <entity name="App\Domain\Model\Participant\Participant" table="participant">
        <id name="id" length="36">
            <generator strategy="NONE" />
        </id>

        <field name="name" length="128" />
        <field name="surname" length="128" />
        <field name="email" length="255" unique="true" />

        <one-to-many
                field="registrations"
                target-entity="App\Domain\Model\Registration\Registration"
                mapped-by="participant"
        >
            <cascade>
                <cascade-all />
            </cascade>
        </one-to-many>
    </entity>
</doctrine-mapping>
